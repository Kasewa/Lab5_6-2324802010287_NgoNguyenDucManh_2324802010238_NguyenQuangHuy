@{
    Layout = "_MasterLayout";
}
<!-- Header -->
<header class="secureLayout">
    <nav class="top-nav blue-grey lighten-1">
        <div class="nav-wrapper row valign-wrapper">
            <div class="col s12 valign-wrapper">
                <a href="#" data-target="nav-mobile" class="sidenav-trigger"><i class="material-icons">menu</i></a>
                <h5><a class="page-title">Automobile Service Center</a></h5>
            </div>
        </div>
    </nav>
    <ul id="nav-mobile" class="sidenav sidenav-fixed">
        <li class="background blue-grey lighten-1">
            <div class="user-view">
                <a href="#"><img class="circle" src="~/images/logo.jpg" /></a>
                <a href="#"><span class="white-text name">New Dev</span></a>
                <a href="#"><span class="white-text email">newdev@gmail.com</span></a>
            </div>
        </li>
        <li>
            <ul class="collapsible collapsible-accordion">
                <li>
                    <a class="collapsible-header" href="#!">
                        <i class="material-icons">supervisor_account</i>
                        User Administration
                    </a>
                    <div class="collapsible-body">
                        <ul>
                            <li><a href="#!">Customers</a></li>
                            <li><a href="#!">Provision User</a></li>
                            <li><a href="#!">Deactivate User</a></li>
                        </ul>
                    </div>
                </li>
                <li>
                    <a class="collapsible-header" href="#!">
                        <i class="material-icons">perm_data_setting</i>
                        Service Requests
                    </a>
                </li>
                <li>
                    <a class="collapsible-header" href="#!">
                        <i class="material-icons">message</i>
                        Service Notifications
                    </a>
                </li>
                <li>
                    <a class="collapsible-header" href="#!">
                        <i class="material-icons">inbox</i>
                        Promotions
                    </a>
                </li>
                <li>
                    <a class="collapsible-header" href="#!">
                        <i class="material-icons">settings</i>
                        Settings
                    </a>
                </li>
                <li>
                    <a class="collapsible-header" href="#!">
                        <i class="material-icons">exit_to_app</i>
                        Logout
                    </a>
                </li>
            </ul>
        </li>
    </ul>
</header>

<!-- Render Body -->
<main class="secureLayout">
    <div class="row margin-bottom-0px">
        <div class="col s12">
            @RenderBody()
        </div>
    </div>
</main>

<footer class="page-footer blue-grey lighten-1 secureLayout">
    <div class="container">
        <div class="row">
            <div class="col s3 offset-s2">
                <h5 class="white-text">About Us</h5>
                <p class="grey-text text-lighten-4">
                    Automobile Service Center is certified Company to perform car services. Our Workshop
                    operations started in the month of October 2018. We primarily focus on providing better
                    services to our customers, and as a result of the hard work we were awarded as the "Best
                    Service" for this year 2019 and that has within a short period of time.
                </p>
            </div>
            <div class="col s4 offset-s1">
                <h5 class="white-text">Additional Services:</h5>
                <ul>
                    <li><a class="white-text" href="#">Services</a></li>
                    <li><a class="white-text" href="#">Finance</a></li>
                    <li><a class="white-text" href="#">Used Cars</a></li>
                    <li><a class="white-text" href="#">Insurance</a></li>
                    <li><a class="white-text" href="#">Driving School</a></li>
                </ul>
            </div>
            <div class="col s2">
                <h5 class="white-text">Connect:</h5>
                <ul>
                    <li><a class="white-text" href="#">Facebook</a></li>
                    <li><a class="white-text" href="#">LinkedIn</a></li>
                    <li><a class="white-text" href="#">Twitter</a></li>
                    <li><a class="white-text" href="#">Youtube</a></li>
                </ul>
            </div>
        </div>
    </div>
    <div class="footer-copyright">
        Powered by <a href="http://materializecss.com">Materialize</a>
    </div>
</footer>
